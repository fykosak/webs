{
  "name": "fykosak/web-fol",
  "keywords": [
    "nette"
  ],
  "type": "project",
  "license": [
    "MIT",
    "BSD-3-Clause",
    "GPL-2.0",
    "GPL-3.0"
  ],
  "require": {
    "php": ">= 8.1",
    "nette/nette": "^v3.2.3",
    "fykosak/fksdb-downloader-core": "dev-master",
    "fykosak/nette-fks-utils": "v0.2.1.0-RC6",
    "ext-soap": "*",
    "ext-curl": "*",
    "ext-dom": "*",
    "ext-gettext": "*",
    "ext-json": "*",
    "68publishers/asset": "^3.3",
    "netresearch/jsonmapper": "^4.0",
    "jumbojett/openid-connect-php": "^1.0"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "3.7.2",
    "nette/tester": "^v2.6.0",
    "phpstan/phpstan": "2.1.30",
    "phpstan/phpstan-nette": "^2.0.6",
    "phpstan/phpstan-strict-rules": "2.0.7"
  },
  "scripts": {
    "clearTestCache": "rm -rf temp/tester/",
    "testPSR": "php -e vendor/squizlabs/php_codesniffer/bin/phpcs --standard=PSR12 --exclude=Generic.Files.LineLength --extensions=php,phpt app/ tests/",
    "testPHPStan": "vendor/bin/phpstan analyse",
    "test": [
      "@clearTestCache",
      "tests/api/commandWithApi.sh vendor/bin/tester tests/ -p php -s -c tests/php.ini -j 8"
    ],
    "latteLint": "vendor/bin/latte-lint app --strict",
    "testCoverage": [
      "@clearTestCache",
      "tests/api/commandWithApi.sh vendor/bin/tester tests -p php --coverage coverage.html --coverage-src app -s -c tests/php.ini -j 8"
    ]
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Tests\\": "tests/"
    }
  }
}
